generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id                  String              @id @default(cuid())
  slug                String              @unique
  name                String
  nameEn              String?
  description         String?
  descriptionEn       String?
  type                ProductType
  basePriceUAH        Int?
  basePriceUSD        Int?
  inStock             Boolean             @default(true)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  dimensions          String?
  dimensionsEn        String?
  info                String?
  infoEn              String?
  group               ProductGroup?
  sortCatalog         Int                 @default(0)
  sortSlider          Int?
  showInNewArrivals   Boolean             @default(true)
  isAddon             Boolean             @default(false)
  offerNote           String?
  offerNoteEn         String?
  packagingTemplateId String?
  status              ProductStatus       @default(DRAFT)
  packagingTemplate   PackagingTemplate?  @relation(fields: [packagingTemplateId], references: [id])
  ProductCollection   ProductCollection[]
  costProfile         ProductCostProfile?
  inventory           ProductInventory?
  materialUsages      ProductMaterial[]
  variants            ProductVariant[]
  productionBatches   ProductionBatch[]
  artisanProductions  ArtisanProduction[]

  @@index([type])
  @@index([group])
  @@index([status])
  @@index([inStock])
  @@index([packagingTemplateId])
}

model ProductCostProfile {
  id               String   @id @default(cuid())
  productId        String   @unique
  materialsCostUAH Int      @default(0)
  laborCostUAH     Int      @default(0)
  packagingCostUAH Int      @default(0)
  shippingCostUAH  Int      @default(0)
  otherCostUAH     Int      @default(0)
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductInventory {
  id               String   @id @default(cuid())
  productId        String   @unique
  finishedGoodsQty Int      @default(0)
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Material {
  id            String                    @id @default(cuid())
  name          String
  unit          String                    @default("pcs")
  stockQty      Float                     @default(0)
  notes         String?
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  unitCostUAH   Float                     @default(0)
  category      MaterialCategory          @default(HARDWARE)
  color         String                    @default("")
  productUsages ProductMaterial[]
  batchUsages   ProductionBatchMaterial[]

  @@unique([name, category, color])
  @@index([category])
  @@index([name])
}

model PackagingTemplate {
  id               String    @id @default(cuid())
  name             String    @unique
  costUAH          Int       @default(0)
  boxLabel         String?
  tissuePaperQty   Int       @default(1)
  tagCardQty       Int       @default(1)
  tagThreadQty     Int       @default(1)
  roundStickerQty  Int       @default(1)
  squareStickerQty Int       @default(1)
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  products         Product[]
}

model ProductionBatch {
  id                String                    @id @default(cuid())
  productId         String
  producedAt        DateTime
  qty               Int
  laborTotalUAH     Int                       @default(0)
  laborPerUnitUAH   Int                       @default(0)
  materialsTotalUAH Int                       @default(0)
  packagingTotalUAH Int                       @default(0)
  notes             String?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  product           Product                   @relation(fields: [productId], references: [id], onDelete: Cascade)
  materials         ProductionBatchMaterial[]

  @@index([producedAt])
  @@index([productId, producedAt])
}

model ProductionBatchMaterial {
  id           String          @id @default(cuid())
  batchId      String
  materialId   String
  qtyUsed      Float
  unitCostUAH  Int             @default(0)
  totalCostUAH Int             @default(0)
  createdAt    DateTime        @default(now())
  batch        ProductionBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  material     Material        @relation(fields: [materialId], references: [id])

  @@index([batchId])
  @@index([materialId])
}

model ProductMaterial {
  id           String   @id @default(cuid())
  productId    String
  materialId   String
  quantity     Float
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  variantColor String   @default("")
  material     Material @relation(fields: [materialId], references: [id])
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, materialId, variantColor])
  @@index([productId])
  @@index([materialId])
  @@index([productId, variantColor])
}

model ProductVariant {
  id                    String                   @id @default(cuid())
  productId             String
  sku                   String?                  @unique
  color                 String?
  colorEn               String?
  modelSize             String?
  pouchColor            String?
  hex                   String?
  image                 String?
  inStock               Boolean                  @default(true)
  priceUAH              Int?
  priceUSD              Int?
  sortCatalog           Int?                     @default(0)
  sortBestsellers       Int?                     @default(0)
  discountUAH           Int?                     @default(0)
  shippingNote          String?
  discountPercent       Int?                     @default(0)
  availabilityStatus    AvailabilityStatus       @default(IN_STOCK)
  product               Product                  @relation(fields: [productId], references: [id])
  usedAsAddonOnVariants ProductVariantAddon[]    @relation("AddonVariantOnBag")
  addonsOnVariant       ProductVariantAddon[]    @relation("BagVariantAddons")
  images                ProductVariantImage[]
  inventory             ProductVariantInventory?
  straps                ProductVariantStrap[]
  pouches               ProductVariantPouch[]
  sizes                 ProductVariantSize[]
  artisanRates          ArtisanRate[]
  artisanProductions    ArtisanProduction[]

  @@index([productId, color, modelSize, pouchColor])
}

model ProductVariantInventory {
  id               String         @id @default(cuid())
  variantId        String         @unique
  finishedGoodsQty Int            @default(0)
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @default(now()) @updatedAt
  variant          ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
}

model ProductVariantImage {
  id        String         @id @default(cuid())
  variantId String
  url       String
  sort      Int            @default(0)
  hover     Boolean        @default(false)
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  @@index([variantId, sort])
}

model ProductVariantStrap {
  id            String                     @id @default(cuid())
  variantId     String
  name          String
  slug          String?
  imageUrl      String?
  mainImageUrl  String?
  sort          Int                        @default(0)
  extraPriceUAH Int                        @default(0)
  variant       ProductVariant             @relation(fields: [variantId], references: [id])
  images        ProductVariantStrapImage[]

  @@index([variantId, sort])
}

model ProductVariantStrapImage {
  id      String              @id @default(cuid())
  strapId String
  url     String
  sort    Int                 @default(0)
  strap   ProductVariantStrap @relation(fields: [strapId], references: [id], onDelete: Cascade)
}

model ProductVariantPouch {
  id            String                     @id @default(cuid())
  variantId     String
  color         String
  imageUrl      String?
  mainImageUrl  String?
  extraPriceUAH Int                        @default(0)
  sort          Int                        @default(0)
  variant       ProductVariant             @relation(fields: [variantId], references: [id], onDelete: Cascade)
  images        ProductVariantPouchImage[]

  @@index([variantId, sort])
}

model ProductVariantPouchImage {
  id      String              @id @default(cuid())
  pouchId String
  url     String
  sort    Int                 @default(0)
  pouch   ProductVariantPouch @relation(fields: [pouchId], references: [id], onDelete: Cascade)
}

model ProductVariantSize {
  id            String                    @id @default(cuid())
  variantId     String
  size          String
  imageUrl      String?
  mainImageUrl  String?
  extraPriceUAH Int                       @default(0)
  sort          Int                       @default(0)
  variant       ProductVariant            @relation(fields: [variantId], references: [id], onDelete: Cascade)
  images        ProductVariantSizeImage[]

  @@index([variantId, sort])
}

model ProductVariantSizeImage {
  id     String             @id @default(cuid())
  sizeId String
  url    String
  sort   Int                @default(0)
  size   ProductVariantSize @relation(fields: [sizeId], references: [id], onDelete: Cascade)
}

model ProductVariantAddon {
  id             String         @id @default(cuid())
  variantId      String
  addonVariantId String
  sort           Int            @default(0)
  addonVariant   ProductVariant @relation("AddonVariantOnBag", fields: [addonVariantId], references: [id])
  variant        ProductVariant @relation("BagVariantAddons", fields: [variantId], references: [id])

  @@unique([variantId, addonVariantId])
  @@index([variantId, sort])
  @@index([addonVariantId])
}

model Customer {
  id        String   @id @default(cuid())
  email     String?  @unique
  phone     String?  @unique
  name      String?
  createdAt DateTime @default(now())
  orders    Order[]
}

model Order {
  id                 String        @id @default(cuid())
  status             OrderStatus   @default(PENDING)
  createdAt          DateTime      @default(now())
  subtotalUAH        Int
  deliveryUAH        Int           @default(0)
  discountUAH        Int           @default(0)
  totalUAH           Int
  customerName       String
  customerSurname    String
  customerPatronymic String?
  customerPhone      String
  customerEmail      String?
  npCityRef          String
  npCityName         String
  npWarehouseRef     String
  npWarehouseName    String
  paymentMethod      PaymentMethod
  paymentId          String?
  paymentStatus      String?
  paymentRaw         Json?
  customerId         String?
  shortNumber        Int           @unique @default(autoincrement())
  grossProfitUAH     Int           @default(0)
  itemsCostUAH       Int           @default(0)
  paymentFeeUAH      Int           @default(0)
  customer           Customer?     @relation(fields: [customerId], references: [id])
  items              OrderItem[]

  @@index([status, createdAt])
  @@index([customerPhone])
}

model OrderItem {
  id             String  @id @default(cuid())
  orderId        String
  productId      String?
  variantId      String?
  name           String
  color          String?
  modelSize      String?
  pouchColor     String?
  image          String?
  priceUAH       Int
  qty            Int
  strapName      String?
  addons         Json?
  discountUAH    Int     @default(0)
  lineRevenueUAH Int     @default(0)
  totalCostUAH   Int     @default(0)
  unitCostUAH    Int     @default(0)
  order          Order   @relation(fields: [orderId], references: [id])
}

model Supplier {
  id          String     @id @default(cuid())
  name        String     @unique
  contactName String?
  phone       String?
  email       String?
  currency    String     @default("UAH")
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  purchases   Purchase[]
}

model Purchase {
  id            String         @id @default(cuid())
  supplierId    String
  status        PurchaseStatus @default(DRAFT)
  purchasedAt   DateTime
  invoiceNumber String?
  subtotalUAH   Int            @default(0)
  deliveryUAH   Int            @default(0)
  totalUAH      Int            @default(0)
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  supplier      Supplier       @relation(fields: [supplierId], references: [id])
  items         PurchaseItem[]

  @@index([supplierId, purchasedAt])
  @@index([status, purchasedAt])
}

model PurchaseItem {
  id           String   @id @default(cuid())
  purchaseId   String
  title        String
  qty          Float
  unit         String   @default("pcs")
  unitPriceUAH Int
  totalUAH     Int
  purchase     Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@index([purchaseId])
}

model Expense {
  id                 String              @id @default(cuid())
  title              String
  category           ExpenseCategory
  amountUAH          Int
  expenseDate        DateTime
  notes              String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  artisanProductions ArtisanProduction[] @relation("ArtisanProductionPaidExpense")

  @@index([expenseDate, category])
}

model Artisan {
  id               String               @id @default(cuid())
  name             String
  phone            String?
  telegramUserId   String?              @unique
  telegramChatId   String?              @unique
  telegramUsername String?
  accessCode       String               @unique
  isActive         Boolean              @default(true)
  notes            String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  rates            ArtisanRate[]
  productions      ArtisanProduction[]
  sessions         TelegramBotSession[]

  @@index([name])
  @@index([isActive])
}

model ArtisanRate {
  id             String              @id @default(cuid())
  artisanId      String
  variantId      String
  ratePerUnitUAH Int
  isActive       Boolean             @default(true)
  notes          String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  artisan        Artisan             @relation(fields: [artisanId], references: [id], onDelete: Cascade)
  variant        ProductVariant      @relation(fields: [variantId], references: [id], onDelete: Cascade)
  productions    ArtisanProduction[]

  @@unique([artisanId, variantId])
  @@index([artisanId, isActive])
  @@index([variantId, isActive])
}

model ArtisanProduction {
  id                       String                  @id @default(cuid())
  artisanId                String
  productId                String
  variantId                String
  rateId                   String?
  qty                      Int
  ratePerUnitSnapshotUAH   Int
  totalLaborUAH            Int
  producedAt               DateTime                @default(now())
  status                   ArtisanProductionStatus @default(SUBMITTED)
  source                   ArtisanProductionSource @default(TELEGRAM_BOT)
  notes                    String?
  telegramUpdateId         Int?
  approvedAt               DateTime?
  approvedByTelegramUserId String?
  paidAt                   DateTime?
  paidExpenseId            String?
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  artisan                  Artisan                 @relation(fields: [artisanId], references: [id], onDelete: Cascade)
  product                  Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant                  ProductVariant          @relation(fields: [variantId], references: [id], onDelete: Cascade)
  rate                     ArtisanRate?            @relation(fields: [rateId], references: [id], onDelete: SetNull)
  paidExpense              Expense?                @relation("ArtisanProductionPaidExpense", fields: [paidExpenseId], references: [id], onDelete: SetNull)

  @@index([artisanId, producedAt])
  @@index([productId, producedAt])
  @@index([variantId, producedAt])
  @@index([status, producedAt])
  @@index([rateId])
  @@index([paidExpenseId])
}

model TelegramBotSession {
  id           String                 @id @default(cuid())
  chatId       String                 @unique
  userId       String?
  artisanId    String?
  step         TelegramBotSessionStep @default(IDLE)
  draftPayload Json?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  artisan      Artisan?               @relation(fields: [artisanId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([artisanId])
}

model PreorderLead {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  productId    String
  productSlug  String?
  productName  String
  variantId    String
  variantColor String?
  strapId      String?
  contactName  String?
  contact      String
  comment      String?
  source       String?

  @@index([createdAt])
  @@index([productId])
  @@index([variantId])
}

model BlogPost {
  id             String         @id @default(cuid())
  slug           String         @unique
  title          String
  excerpt        String
  description    String
  coverImage     String
  coverImageAlt  String
  keywords       String[]       @default([])
  publishedAt    DateTime?
  readingMinutes Int            @default(4)
  status         BlogPostStatus @default(DRAFT)
  sections       Json
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([status, publishedAt])
}

model Collection {
  id                String              @id
  slug              String              @unique
  name              String
  h1                String
  metaTitle         String?
  metaDescription   String?
  intro             String?
  faqJson           Json?
  defaultType       ProductType?
  defaultGroup      ProductGroup?
  isIndexable       Boolean             @default(true)
  sort              Int                 @default(0)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime
  ProductCollection ProductCollection[]

  @@index([isIndexable, sort])
}

model ProductCollection {
  id           String     @id
  productId    String
  collectionId String
  sort         Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime
  Collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  Product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, collectionId])
  @@index([collectionId, sort])
  @@index([productId])
}

enum ProductType {
  BAG
  BACKPACK
  CASE
  SHOPPER
  BELT_BAG
  ORNAMENTS
  ACCESSORY
}

enum BlogPostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ProductGroup {
  BEADS
  WEAVING
}

enum AvailabilityStatus {
  IN_STOCK
  PREORDER
  OUT_OF_STOCK
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  FULFILLED
}

enum PaymentMethod {
  LIQPAY
  COD
  BANK_TRANSFER
  WAYFORPAY
}

enum ExpenseCategory {
  ADS
  PACKAGING
  SHIPPING
  PAYMENT_FEES
  PAYROLL
  PHOTO
  SOFTWARE
  RENT
  OTHER
}

enum MaterialCategory {
  BEADS
  THREADS
  STRAPS
  FABRIC
  HARDWARE
  CORDS
}

enum PurchaseStatus {
  DRAFT
  ORDERED
  RECEIVED
  PAID
  CANCELLED
}

enum ArtisanProductionStatus {
  SUBMITTED
  APPROVED
  PAID
  REJECTED
}

enum ArtisanProductionSource {
  TELEGRAM_BOT
  IMPORT
  MANUAL
}

enum TelegramBotSessionStep {
  IDLE
  AWAITING_QTY
  AWAITING_CONFIRM
}
